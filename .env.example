HAPROXY_VERSION=3.3.10

# Local image name. For Docker Hub, use your-dockerhub-id/haproxy-logrotate.
IMAGE_NAME=haproxy-logrotate

TZ=Asia/Seoul

HAPROXY_MAXCONN=4096
HAPROXY_WRITE_PORT=5432
HAPROXY_READ_PORT=5433
HAPROXY_STATS_PORT=8404

# Defaults match the service names used by ../postgresql-logrotate.
# In production, set these to the DB server IPs or DNS names.
POSTGRES_MASTER_HOST=postgres-master
POSTGRES_MASTER_PORT=5432
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_REPLICA_PORT=5432
